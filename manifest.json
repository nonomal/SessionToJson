{
  "manifest_version": 3,
  "name": "SessionToJson",
  "version": "0.1.0",
  "description": "读取当前页面中的 JSON，并转换为 Codex 可用的 JSON。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SessionToJson",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
